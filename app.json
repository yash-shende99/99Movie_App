{
  "expo": {
    "name": "99Movies",
    "slug": "99Movie_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "movies",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.yash.movies99"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "publicPath": "/",
      "favicon": "./assets/images/logo.png",
      "meta": {
        "viewport": "width=device-width, initial-scale=1.0, maximum-scale=1.0"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a118df82-f67c-4c93-b5c6-e955afc6d3d8"
      }
    }
  }
}
